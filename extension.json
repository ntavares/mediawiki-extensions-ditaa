{
	"name": "Ditaa",
	"author": [
		"[https://www.mediawiki.org/wiki/User:Nuno_Tavares Nuno Tavares]",
		"CoffMan"
	],
	"url": "https://www.mediawiki.org/wiki/Extension:Ditaa",
	"description": "Render nice diagrams from ASCII",
	"license-name": "GPL-2.0",
	"type": "parserhook",
	"version": "1.1",
	"ConfigRegistry": [],
        "AutoloadNamespaces": {
                "MediaWiki\\Extension\\Ditaa\\": "src/"
        },
	"ResourceModules": [],
	"ResourceFileModulePaths": [],
	"Hooks": {
		"ParserFirstCallInit": "main"
	},
	"HookHandlers": {
		"main": {
			"class": "MediaWiki\\Extension\\Ditaa\\Ditaa"
		}
	},
	"config": {
		"DitaaCommand": {
			"value": "/usr/local/bin/wiki_ditaa.sh",
			"description": "Path to the wrapper script",
			"public": true
		}
	},
	"manifest_version": 2,
	"requires": {
		"MediaWiki": ">= 1.29.0"
	}
}
